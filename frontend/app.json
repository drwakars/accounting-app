{
  "expo": {
    "name": "دفتر الحسابات",
    "slug": "accounting-ledger",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "accountingledger",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.accountingledger.app",
      "infoPlist": {
        "NSCameraUsageDescription": "التطبيق يحتاج للكاميرا لتصوير المستندات",
        "NSPhotoLibraryUsageDescription": "التطبيق يحتاج للوصول للصور",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.accountingledger.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#007AFF"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#007AFF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ff876b7f-09d2-4294-822f-7916857f65b4"
      }
    }
  }
}
